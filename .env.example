# Database
DATABASE_URL=sqlite:////var/lib/appcenter/appcenter.db

# JWT Secret - CHANGE THIS IN PRODUCTION
SECRET_KEY=change-me-in-production-use-a-strong-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# File Upload
UPLOAD_DIR=/var/lib/appcenter/uploads
MAX_UPLOAD_SIZE=2147483648
MAX_ICON_SIZE=5242880

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false
CORS_ORIGINS=*

# Logging
LOG_FILE=/var/log/appcenter/server.log
LOG_LEVEL=INFO

# Remote Support
REMOTE_SUPPORT_ENABLED=false
REMOTE_SUPPORT_APPROVAL_TIMEOUT_SEC=120
REMOTE_SUPPORT_DEFAULT_MAX_DURATION_MIN=60
REMOTE_SUPPORT_MAX_DURATION_MIN=480
GUAC_REVERSE_VNC_HOST=
GUAC_REVERSE_VNC_PORT=5500
NOVNC_TOKEN_FILE=/opt/appcenter/novnc/tokens.txt
NOVNC_WS_PATH=/novnc-ws
REMOTE_SUPPORT_NOVNC_MODE=iframe
REMOTE_SUPPORT_WS_MODE=external

REMOTE_SUPPORT_VNC_PASSWORD=
